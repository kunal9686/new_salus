
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and growth statistics.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "wellnessGoals": { "type": "string" },
        "streakCount": { "type": "number", "default": 0 },
        "totalEntries": { "type": "number", "default": 0 }
      },
      "required": ["id", "email"]
    },
    "JournalEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "JournalEntry",
      "type": "object",
      "description": "A private reflection or guided module response.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["free", "ikigai", "life-audit", "identity", "anxiety", "cbt"] },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "moduleData": { "type": "object", "description": "Structured data for guided modules." }
      },
      "required": ["id", "userId", "type", "content", "timestamp"]
    },
    "MoodLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MoodLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "mood": { "type": "string", "enum": ["very-low", "neutral", "good", "great"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "mood", "timestamp"]
    },
    "Story": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": {
          "type": "object",
          "properties": {
            "background": { "type": "string" },
            "struggle": { "type": "string" },
            "breakingPoint": { "type": "string" },
            "turningPoint": { "type": "string" },
            "lessons": { "type": "string" },
            "reflectionPrompt": { "type": "string" }
          }
        },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile and growth stats."
        }
      },
      {
        "path": "/users/{userId}/journalEntries/{entryId}",
        "definition": {
          "entityName": "JournalEntry",
          "schema": { "$ref": "#/backend/entities/JournalEntry" },
          "description": "Private reflections and module results."
        }
      },
      {
        "path": "/users/{userId}/moodLogs/{logId}",
        "definition": {
          "entityName": "MoodLog",
          "schema": { "$ref": "#/backend/entities/MoodLog" },
          "description": "Daily mood tracking data."
        }
      },
      {
        "path": "/stories/{storyId}",
        "definition": {
          "entityName": "Story",
          "schema": { "$ref": "#/backend/entities/Story" },
          "description": "Curated resilience stories."
        }
      }
    ]
  }
}
